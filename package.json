{
  "name": "next-codex-workflow",
  "version": "0.1.0",
  "description": "Repo-local Codex workflow installer for existing Next.js repositories.",
  "type": "module",
  "bin": {
    "next-codex-workflow": "./dist/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "vendor-skills"
  ],
  "scripts": {
    "build": "tsup",
    "check": "npm run typecheck && npm run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
