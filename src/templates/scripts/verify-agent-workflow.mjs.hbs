#!/usr/bin/env node
// Generated by next-codex-workflow-kit
import { access, readFile } from "node:fs/promises";
import { constants } from "node:fs";
import { spawn } from "node:child_process";
import path from "node:path";
import process from "node:process";

const CHECK_ORDER = ["lint", "typecheck", "test", "build"];
const LOCKFILE_PRIORITY = [
  { file: "pnpm-lock.yaml", packageManager: "pnpm" },
  { file: "yarn.lock", packageManager: "yarn" },
  { file: "bun.lockb", packageManager: "bun" },
  { file: "bun.lock", packageManager: "bun" },
  { file: "package-lock.json", packageManager: "npm" }
];

async function pathExists(targetPath) {
  try {
    await access(targetPath, constants.F_OK);
    return true;
  } catch {
    return false;
  }
}

async function loadPackageJson() {
  const packageJsonPath = path.join(process.cwd(), "package.json");
  const raw = await readFile(packageJsonPath, "utf8");
  return JSON.parse(raw);
}

async function detectPackageManager() {
  for (const entry of LOCKFILE_PRIORITY) {
    if (await pathExists(path.join(process.cwd(), entry.file))) {
      return entry.packageManager;
    }
  }

  return "npm";
}

function commandForScript(packageManager, scriptName) {
  switch (packageManager) {
    case "pnpm":
      return { command: "pnpm", args: [scriptName] };
    case "yarn":
      return { command: "yarn", args: [scriptName] };
    case "bun":
      return { command: "bun", args: ["run", scriptName] };
    case "npm":
    default:
      return { command: "npm", args: ["run", scriptName] };
  }
}

async function runCommand(command, args) {
  const startedAt = Date.now();

  return await new Promise((resolve) => {
    const child = spawn(command, args, {
      cwd: process.cwd(),
      shell: process.platform === "win32",
      stdio: ["ignore", "pipe", "pipe"]
    });

    let stdout = "";
    let stderr = "";

    child.stdout.on("data", (chunk) => {
      stdout += String(chunk);
    });

    child.stderr.on("data", (chunk) => {
      stderr += String(chunk);
    });

    child.on("close", (code) => {
      const output = `${stdout}\n${stderr}`.trim();

      resolve({
        status: code === 0 ? "passed" : "failed",
        durationMs: Date.now() - startedAt,
        output,
        exitCode: code ?? 1
      });
    });
  });
}

async function resolveTypecheckFallback(packageJson) {
  const typescriptDeclared =
    packageJson.devDependencies?.typescript ?? packageJson.dependencies?.typescript ?? null;
  const tsconfigExists = await pathExists(path.join(process.cwd(), "tsconfig.json"));
  const localTscPath = path.join(process.cwd(), "node_modules", "typescript", "bin", "tsc");

  if (!typescriptDeclared && !tsconfigExists) {
    return null;
  }

  if (!(await pathExists(localTscPath))) {
    return null;
  }

  return {
    label: "typecheck",
    command: process.execPath,
    args: [localTscPath, "--noEmit"]
  };
}

async function main() {
  const packageJson = await loadPackageJson();
  const packageManager = await detectPackageManager();
  const scripts = packageJson.scripts ?? {};
  const results = [];

  for (const label of CHECK_ORDER) {
    if (label === "typecheck" && !scripts.typecheck) {
      const fallback = await resolveTypecheckFallback(packageJson);

      if (!fallback) {
        results.push({
          label,
          command: "not-configured",
          status: "not-configured",
          durationMs: 0,
          summary: "No typecheck script and no safe local tsc fallback were found."
        });
        continue;
      }

      const fallbackResult = await runCommand(fallback.command, fallback.args);

      results.push({
        label,
        command: `${fallback.command} ${fallback.args.join(" ")}`,
        status: fallbackResult.status,
        durationMs: fallbackResult.durationMs,
        summary: fallbackResult.output || `Command exited with code ${fallbackResult.exitCode}.`
      });
      continue;
    }

    if (!scripts[label]) {
      results.push({
        label,
        command: "not-configured",
        status: "not-configured",
        durationMs: 0,
        summary: `No ${label} script was configured in package.json.`
      });
      continue;
    }

    const scriptCommand = commandForScript(packageManager, label);
    const execution = await runCommand(scriptCommand.command, scriptCommand.args);

    results.push({
      label,
      command: `${scriptCommand.command} ${scriptCommand.args.join(" ")}`,
      status: execution.status,
      durationMs: execution.durationMs,
      summary: execution.output || `Command exited with code ${execution.exitCode}.`
    });
  }

  const blocking = results.some((result) => result.status === "failed");

  process.stdout.write(
    `${JSON.stringify(
      {
        packageManager,
        blocking,
        results
      },
      null,
      2
    )}\n`
  );

  process.exitCode = blocking ? 1 : 0;
}

void main().catch((error) => {
  process.stderr.write(`${error instanceof Error ? error.stack ?? error.message : String(error)}\n`);
  process.exitCode = 1;
});
