            "Re-run node scripts/run-lighthouse.mjs after the dependency is available."
          ]
        },
        null,
        2
      )}\n`
    );
    return;
  }

  const execution = await runCommand(process.execPath, [
    lhciCli,
    "autorun",
    "--config=agent-workflow/config/lighthouserc.cjs"
  ]);

  process.stdout.write(
    `${JSON.stringify(
      {
        status: execution.code === 0 ? "completed" : "failed",
        auditedRoutes: ROUTES,
        buildCommandUsed: config.workflow?.buildCommand ?? "not-configured",
        startCommandUsed: config.workflow?.startCommand ?? "not-configured",
        lighthouseResults: [],
