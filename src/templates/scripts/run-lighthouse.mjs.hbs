const require = createRequire(import.meta.url);
const ROUTES = {{routes}};

async function pathExists(targetPath) {
  try {
    await access(targetPath, constants.F_OK);
    return true;
  } catch {
    return false;
  }
}

async function resolveLhciCli() {
  const candidates = [
    path.join(process.cwd(), "node_modules", "@lhci", "cli", "src", "cli.js"),
    path.join(process.cwd(), "node_modules", "@lhci", "cli", "bin", "lhci.js")
  ];

  for (const candidate of candidates) {
    if (await pathExists(candidate)) {
      return candidate;
    }
  }

  return null;
}

async function runCommand(command, args) {
  return await new Promise((resolve) => {
    const child = spawn(command, args, {
      cwd: process.cwd(),
      shell: process.platform === "win32",
      stdio: ["ignore", "pipe", "pipe"]
    });

    let stdout = "";
    let stderr = "";

    child.stdout.on("data", (chunk) => {
      stdout += String(chunk);
    });

    child.stderr.on("data", (chunk) => {
      stderr += String(chunk);
    });

    child.on("close", (code) => {
      resolve({
        code: code ?? 1,
        output: `${stdout}\n${stderr}`.trim()
      });
    });
  });
}

async function main() {
  const configPath = path.join(process.cwd(), "agent-workflow", "config", "lighthouserc.cjs");
  const config = require(configPath);
  const lhciCli = await resolveLhciCli();

  if (!lhciCli) {
    process.stdout.write(
      `${JSON.stringify(
        {
          status: "incomplete",
          auditedRoutes: ROUTES,
          buildCommandUsed: config.workflow?.buildCommand ?? "not-configured",
