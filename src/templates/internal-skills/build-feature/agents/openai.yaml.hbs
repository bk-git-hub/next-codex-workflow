interface:
  display_name: "Build Feature"
  short_description: "Implement the plan with subagents"
  default_prompt: "Use $build-feature to implement the approved plan in PLAN.md, spawn at least one focused subagent before coding, then spawn verifier and reviewer, and do not fall back to single-agent execution if spawning is unavailable."

policy:
